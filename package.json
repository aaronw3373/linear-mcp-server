{
  "name": "linear-mcp-server",
  "version": "0.1.0-weinberg",
  "description": "MCP server for Linear API. Patched for Weinberg agent system: team key resolution, status name resolution, label assignment, project assignment, linear_create_label, linear_create_project, linear_list_projects.",
  "type": "module",
  "bin": {
    "linear-mcp-server": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "dependencies": {
    "@linear/sdk": "^33.0.0",
    "@modelcontextprotocol/sdk": "^1.0.3",
    "dotenv": "^16.4.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aaronw3373/linear-mcp-server.git"
  },
  "keywords": ["linear", "mcp", "model context protocol", "api", "server"],
  "author": "Model Context Protocol",
  "license": "MIT"
}
